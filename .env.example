# Development-only placeholders. Replace every CHANGE_ME value in local .env.
COMPOSE_PROJECT_NAME=vehicle-insurance-ha

POSTGRES_IMAGE=postgres:18.1-bookworm
PGPOOL_VERSION=4.7.2-1.pgdg12+1
PYTHON_IMAGE=python:3.13.1-slim-bookworm
ALPINE_IMAGE=alpine:3.21.2

POSTGRES_DB=vehicle_insurance
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_LOCAL_POSTGRES_PASSWORD
REPLICATION_PASSWORD=CHANGE_ME_LOCAL_REPLICATION_PASSWORD
REPMGR_PASSWORD=CHANGE_ME_LOCAL_REPMGR_PASSWORD
HEALTHCHECK_PASSWORD=CHANGE_ME_LOCAL_HEALTHCHECK_PASSWORD
BACKUP_PASSWORD=CHANGE_ME_LOCAL_BACKUP_PASSWORD

APP_AGENT_PASSWORD=CHANGE_ME_LOCAL_AGENT_PASSWORD
APP_ADJUSTER_PASSWORD=CHANGE_ME_LOCAL_ADJUSTER_PASSWORD
APP_AUDITOR_PASSWORD=CHANGE_ME_LOCAL_AUDITOR_PASSWORD

APP_HOST_PORT=8000
PGPOOL_HOST_BIND=127.0.0.1
PGPOOL_HOST_PORT=9999
